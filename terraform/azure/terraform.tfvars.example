# Copy to terraform.tfvars and fill in values before running terraform plan/apply

environment  = "dev"
project_name = "patching-system"

resource_group_name = "patching-system-rg"
location            = "eastus"
subscription_id     = "00000000-0000-0000-0000-000000000000"

# Maintenance window: weekly Saturday at 02:00 UTC, 4-hour window
maintenance_start_datetime  = "2026-06-07 02:00"
maintenance_recur_every     = "1Week Saturday"
maintenance_window_duration = "04:00"

log_retention_days = 30

# Leave empty to skip action group email receiver
alert_email = ""

tags = {
  Owner      = "platform-team"
  CostCenter = "infra"
}

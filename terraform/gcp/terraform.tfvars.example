# Copy to terraform.tfvars and fill in values before running terraform plan/apply

environment  = "dev"
project_name = "patching-system"

project_id = "your-gcp-project-id"
region     = "us-central1"

# Cron: Saturday at 02:00 UTC
patch_schedule_cron     = "0 2 * * SAT"
patch_schedule_timezone = "UTC"

pubsub_message_retention = "604800s"  # 7 days
log_sink_bucket_location = "US"
log_retention_days       = 30

# Leave empty to skip notification channel
alert_email = ""
